# =============================================================================
# EarthLedger Agro — Environment Variables
# Copy this file to .env and fill in your keys
# =============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here

# ── 1. Weather API (OpenWeather) ─────────────────────────────────────────────
# Sign up: https://openweathermap.org/api
# Free tier: 1,000 calls/day — Current + 5-day forecast
OPENWEATHER_API_KEY=your-openweather-api-key-here

# ── 2. Maps & Location (Mapbox) ─────────────────────────────────────────────
# Sign up: https://account.mapbox.com/auth/signup/
# Free tier: 50,000 map loads/month — very generous
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here

# ── 3. AI Chatbot — LLM (OpenAI) ────────────────────────────────────────────
# Sign up: https://platform.openai.com/signup
# Model: gpt-4o-mini recommended (cheapest, smartest for chatbot)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── 4. AI Chatbot — LLM Alternative (Groq — FREE & FAST) ────────────────────
# Sign up: https://console.groq.com/
# Free tier: 14,400 requests/day — uses llama3/mixtral
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── 5. Speech-to-Text (Google Cloud Speech) ──────────────────────────────────
# Console: https://console.cloud.google.com/speech
# Free tier: 60 min/month — excellent Hindi/Indian language support
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here
# Or use a service account JSON (recommended for production)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ── 6. Text-to-Speech (ElevenLabs) ──────────────────────────────────────────
# Sign up: https://elevenlabs.io/
# Free tier: 10,000 chars/month — natural voice output
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=your-preferred-voice-id

# ── 7. Carbon Data (Climate TRACE) ──────────────────────────────────────────
# Request access: https://climatetrace.org/
# Free dataset — facility + country level emissions
CLIMATE_TRACE_API_KEY=your-climate-trace-api-key-here

# ── 8. Carbon Credit Pricing (Climatiq) ─────────────────────────────────────
# Sign up: https://www.climatiq.io/
# Free tier: 100 requests/month
CLIMATIQ_API_KEY=your-climatiq-api-key-here

# ── 9. Soil & Agriculture Data (FAO) ────────────────────────────────────────
# Open data: https://www.fao.org/faostat/en/#data
# No key needed for most endpoints — free but messy
FAO_API_BASE_URL=https://www.fao.org/faostat/api/v1

# ── Database (Optional — SQLite default) ─────────────────────────────────────
# DATABASE_URL=sqlite:///earthledger.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/earthledger
