# =============================================================================
# Verdantix — Environment Variables
# Copy this file to .env and fill in your keys
# =============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here

# ── 1. Weather API (OpenWeather) ─────────────────────────────────────────────
# Sign up: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key-here

# ── 2. Maps & Location (Mapbox) ─────────────────────────────────────────────
# Sign up: https://account.mapbox.com/auth/signup/
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here

# ── 3. AI Chatbot — LLM (OpenAI) ────────────────────────────────────────────
# Sign up: https://platform.openai.com/signup
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── 4. AI Chatbot — LLM Alternative (Groq) ──────────────────────────────────
# Sign up: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── 5. Speech-to-Text (Google Cloud Speech) ──────────────────────────────────
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here

# ── 6. Text-to-Speech (ElevenLabs) ──────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=your-preferred-voice-id

# ── 7. Carbon Data (Climate TRACE) ──────────────────────────────────────────
CLIMATE_TRACE_API_KEY=your-climate-trace-api-key-here

# ── 8. Carbon Credit Pricing (Climatiq) ─────────────────────────────────────
CLIMATIQ_API_KEY=your-climatiq-api-key-here

# ── 9. Soil & Agriculture Data (FAO) ────────────────────────────────────────
FAO_API_BASE_URL=https://www.fao.org/faostat/api/v1

# ── 10. Authentication (Clerk) ─────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-here

# ── Database (PostgreSQL / Supabase Transaction Pooler) ───────────────────────
# IMPORTANT: Use Port 6543 for Vercel/Serverless compatibility
DATABASE_URL=postgresql://postgres:password@db.supabase.co:6543/postgres?pgbouncer=true&sslmode=require